// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  user_id                 Int                      @id @default(autoincrement())
  email                   String                   @unique
  name                    String
  slug                    String                   @unique
  timezone                String                   @default("UTC")
  createAt                DateTime                 @default(now())
  updateAt                DateTime                 @updatedAt
  events                  event[]
  bookings                booking[]
  availability            availability_pref[]
  availability_exceptions availability_exception[]
  slots                   slot[]

  @@map("user") //In Prisma, @@map is used to map a Prisma model to an existing database table name
}

// a user can have many events and an event can have only one user.(one to many)
model event {
  event_id         Int       @id @default(autoincrement())
  user_id          Int
  duration         Int
  title            String
  slug             String
  description      String?
  isActive         Boolean   @default(true)
  locationType     String    @default("online")
  locationValue    String?
  bufferbeforeTime Int       @default(0)
  bufferafterTime  Int       @default(0)
  createAt         DateTime  @default(now())
  updateAt         DateTime  @updatedAt
  host             user      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  bookings         booking[]
  slots            slot[]

  @@unique([user_id, slug]) //In Prisma, @@unique is used to create a unique constraint on multiple fields in a model
  @@map("event")
}
model availability_pref {
  pref_id    Int      @id @default(autoincrement())
  user_id    Int
  weekday    Int
  start_time String
  end_time   String
  timezone   String   @default("UTC")
  isActive   Boolean  @default(true)
  createAt   DateTime @default(now())
  updateAt   DateTime @updatedAt
  user       user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, weekday])
  @@map("availability_pref")
}
model availability_exception {
  availability_exception_id Int      @id @default(autoincrement())
  user_id                   Int
  date                      DateTime @db.Date
  type                      String
  start_time                String?
  end_time                  String?
  timezone                  String   @default("UTC")
  createAt                  DateTime @default(now())
  reason                    String?
  updateAt                  DateTime @updatedAt
  user                      user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, date])
  @@map("availability_exception")
}
model slot {
  slot_id    String    @id @default(cuid())
  user_id    Int
  event_id   Int
  start_time DateTime
  end_time   DateTime
  status     String    @default("available")
  createAt   DateTime  @default(now())
  updateAt   DateTime  @updatedAt
  user       user      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  event      event     @relation(fields: [event_id], references: [event_id], onDelete: Cascade)
  bookings   booking[]

  @@unique([event_id, start_time, end_time])
  @@index([user_id, event_id, start_time])
  @@index([event_id, start_time, status])
  @@map("slot")
}
model booking {
  booking_id      Int       @id @default(autoincrement())
  user_id         Int
  event_id        Int
  slot_id         String
  guestName       String
  guestEmail      String
  status          String    @default("pending")
  meetingLink     String?
  calendarEventId String?
  cancelledAt     DateTime?
  createAt        DateTime  @default(now())
  updateAt        DateTime  @updatedAt
  user            user      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  event           event     @relation(fields: [event_id], references: [event_id], onDelete: Cascade)
  slot            slot      @relation(fields: [slot_id], references: [slot_id], onDelete: Cascade)
  @@map("booking")
}
